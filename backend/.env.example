DATABASE_URL=postgresql+asyncpg://collab:collab_pass@localhost:5432/collab_db
REDIS_URL=redis://localhost:6379/0

# LLM provider: openai_compatible (recommended) or anthropic
LLM_PROVIDER=openai_compatible

# OpenAI-compatible relay settings (recommended)
OPENAI_API_KEY=your_token_here
OPENAI_BASE_URL=https://yunwu.ai/v1

# Backward-compatible relay fields (optional fallback)
AI_API_KEY=
AI_BASE_URL=https://yunwu.ai/v1

# Optional direct Anthropic key
ANTHROPIC_API_KEY=

AGENT_MODEL=claude-3-5-sonnet-20241022

JWT_SECRET_KEY=please_replace_with_random_64_chars
CORS_ORIGINS=http://localhost:5173
YJS_WEBSOCKET_PORT=1234
DEBUG=false