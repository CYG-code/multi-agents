DATABASE_URL=postgresql+asyncpg://collab:collab_pass@localhost:5432/collab_db
REDIS_URL=redis://localhost:6379/0

# AI 配置（推荐：中转站）
# 1) 登录中转站后台 -> 令牌页面 -> 添加令牌
# 2) 将令牌填入 AI_API_KEY
# 3) BASE_URL 可按客户端兼容性依次尝试：
#    https://yunwu.ai
#    https://yunwu.ai/v1
#    https://yunwu.ai/v1/chat/completions
AI_API_KEY=your_token_here
AI_BASE_URL=https://yunwu.ai
AGENT_MODEL=claude-3-5-sonnet-20241022

# 兼容直连 Anthropic（可留空）
ANTHROPIC_API_KEY=

JWT_SECRET_KEY=请替换为64位随机字符串
CORS_ORIGINS=http://localhost:5173
YJS_WEBSOCKET_PORT=1234
DEBUG=false
